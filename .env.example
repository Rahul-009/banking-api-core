MONGO_URI=
JWT_SECRET=
RESEND_API_KEY=

# Optional. Used for password reset links, and as the default allowed
# CORS origin if CORS_ORIGINS is not set.
FRONTEND_URL=

# Optional, comma-separated. Overrides FRONTEND_URL for CORS if you need
# to allow multiple origins, e.g. http://localhost:5173,https://myapp.com
CORS_ORIGINS=

NODE_ENV=development
